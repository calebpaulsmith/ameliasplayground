{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Place",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "nameId", "kind", "position"],
    "properties": {
      "id": { "type": "string" },
      "nameId": { "type": "string", "description": "bilingual string id" },
      "kind": { "type": "string" },
      "position": {
        "type": "object",
        "required": ["x", "z"],
        "properties": { "x": { "type": "number" }, "z": { "type": "number" } }
      },
      "beaconColor": { "type": "string", "pattern": "^#?[0-9a-fA-F]{6}$" }
    },
    "additionalProperties": false
  }
}
