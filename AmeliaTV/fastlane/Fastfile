# fastlane lanes for shipping Amelia's Bus Adventure to TestFlight.
#
# Used ONLY by .github/workflows/release-testflight.yml (manual, protected
# `release` environment). Authentication + code signing both use a single
# App Store Connect API key (.p8) — no certificates/profiles to manage by hand.
# See docs/tvos/SHIP_WITHOUT_A_MAC.md for the full setup.
#
# Required env (provided by the workflow from `release` environment secrets):
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_API_KEY_PATH  (App Store Connect API key)
#   APPLE_TEAM_ID                                 (10-char Team ID)
#   IOS_BUNDLE_ID / TVOS_BUNDLE_ID                (your unique bundle ids)

default_platform(:ios)

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_API_KEY_PATH"),
    duration: 1200,
    in_house: false
  )
end

# Archive the given scheme with automatic signing (the API key lets Xcode
# create/refresh the provisioning profile in CI), then upload to TestFlight.
def build_and_upload(scheme:, bundle_id:, destination:, app_platform:)
  key = asc_api_key
  build_app(
    project: "AmeliaTV.xcodeproj",
    scheme: scheme,
    export_method: "app-store",
    destination: destination,
    output_directory: "build",
    output_name: "#{scheme}.ipa",
    xcargs: [
      "-allowProvisioningUpdates",
      "CODE_SIGNING_ALLOWED=YES",
      "CODE_SIGN_STYLE=Automatic",
      "DEVELOPMENT_TEAM=#{ENV.fetch('APPLE_TEAM_ID')}",
      "PRODUCT_BUNDLE_IDENTIFIER=#{bundle_id}"
    ].join(" ")
  )
  upload_to_testflight(
    api_key: key,
    app_platform: app_platform,
    skip_waiting_for_build_processing: true,
    skip_submission: true
  )
end

platform :ios do
  desc "Build the iPhone/iPad app and upload it to TestFlight"
  lane :beta do
    build_and_upload(
      scheme: "AmeliaPad",
      bundle_id: ENV.fetch("IOS_BUNDLE_ID"),
      destination: "generic/platform=iOS",
      app_platform: "ios"
    )
  end
end

platform :tvos do
  desc "Build the Apple TV app and upload it to TestFlight"
  lane :beta do
    build_and_upload(
      scheme: "AmeliaTV",
      bundle_id: ENV.fetch("TVOS_BUNDLE_ID"),
      destination: "generic/platform=tvOS",
      app_platform: "appletvos"
    )
  end
end
