# fastlane lanes for shipping Amelia's Bus Adventure to TestFlight.
#
# Used ONLY by the manual, protected `release` environment workflows:
#   .github/workflows/release-testflight.yml  (build + upload)
#   .github/workflows/match-setup.yml         (one-time signing bootstrap)
#
# Signing model: App Store distribution signing via **fastlane match**. match
# creates an Apple Distribution certificate + App Store provisioning profiles
# using the App Store Connect API key and stores them ENCRYPTED in a private git
# repo, so every CI build reuses them — no registered devices, no Mac, no manual
# certificate juggling. See docs/tvos/SHIP_WITHOUT_A_MAC.md for the full setup.
#
# Required env (provided by the workflows from `release` environment secrets):
#   ASC_KEY_ID, ASC_ISSUER_ID, ASC_API_KEY_PATH  (App Store Connect API key)
#   APPLE_TEAM_ID                                 (10-char Team ID)
#   IOS_BUNDLE_ID / TVOS_BUNDLE_ID                (your unique bundle ids)
#   MATCH_GIT_URL                                 (private repo holding the certs)
#   MATCH_PASSWORD                                (encryption passphrase)
#   MATCH_GIT_BASIC_AUTHORIZATION                 (base64 "user:token" for that repo)

default_platform(:ios)

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV.fetch("ASC_KEY_ID"),
    issuer_id: ENV.fetch("ASC_ISSUER_ID"),
    key_filepath: ENV.fetch("ASC_API_KEY_PATH"),
    duration: 1200,
    in_house: false
  )
end

# Fetch (readonly) — or, on bootstrap, create — the App Store distribution
# certificate + provisioning profile for one app via match. Returns the
# provisioning profile name to sign with.
def sync_signing(api_key:, bundle_id:, match_platform:, readonly:)
  match(
    type: "appstore",
    api_key: api_key,
    app_identifier: bundle_id,
    platform: match_platform,            # "ios" or "tvos"
    git_url: ENV.fetch("MATCH_GIT_URL"),
    storage_mode: "git",
    readonly: readonly,
    fail_on_name_taken: false
  )
  # match exports the installed profile's name here; fall back to its default
  # naming if the env var isn't present.
  ENV["sigh_#{bundle_id}_appstore_profile-name"] ||
    ENV["sigh_#{bundle_id}_appstore"] ||
    "match AppStore #{bundle_id}"
end

# Next TestFlight build number for this app: one past whatever's already
# uploaded, so re-running the workflow never collides on a used build number.
def next_build_number(key, bundle_id, app_platform)
  latest = latest_testflight_build_number(
    api_key: key,
    app_identifier: bundle_id,
    platform: app_platform
  )
  latest.to_i + 1
rescue => e
  UI.message("No existing TestFlight build (#{e.message}); starting at 1.")
  1
end

# Build the given scheme with manual App Store signing (certs/profiles supplied
# by match), then upload to TestFlight.
def build_and_upload(scheme:, bundle_id:, destination:, app_platform:, match_platform:)
  setup_ci                                 # temp keychain so match can install the cert on CI
  key = asc_api_key
  profile_name = sync_signing(
    api_key: key, bundle_id: bundle_id, match_platform: match_platform, readonly: true
  )
  build_number = next_build_number(key, bundle_id, app_platform)
  # Apply manual App Store signing to the APP target only. Passing these as
  # global xcargs broke the build because they also hit the AmeliaCore Swift
  # package ("AmeliaCore does not support provisioning profiles"). The scheme and
  # the app target share a name, so `scheme` is the target to sign.
  update_code_signing_settings(
    use_automatic_signing: false,
    path: "AmeliaTV.xcodeproj",
    targets: [scheme],
    team_id: ENV.fetch("APPLE_TEAM_ID"),
    bundle_identifier: bundle_id,
    code_sign_identity: "Apple Distribution",
    profile_name: profile_name
  )
  build_app(
    project: "AmeliaTV.xcodeproj",
    scheme: scheme,
    export_method: "app-store",
    destination: destination,
    output_directory: "build",
    output_name: "#{scheme}.ipa",
    # Only project-wide settings here (safe for every target); per-target signing
    # is set above via update_code_signing_settings.
    xcargs: "CODE_SIGNING_ALLOWED=YES CURRENT_PROJECT_VERSION=#{build_number}",
    export_options: {
      method: "app-store",
      signingStyle: "manual",
      provisioningProfiles: { bundle_id => profile_name }
    }
  )
  upload_to_testflight(
    api_key: key,
    app_platform: app_platform,
    skip_waiting_for_build_processing: true,
    skip_submission: true
  )
end

# One-time (and idempotent) signing bootstrap: create the distribution cert +
# App Store profiles for BOTH apps and push them, encrypted, to the match repo.
# Runs both apps sequentially in one lane so they share the single distribution
# certificate without racing. Run via .github/workflows/match-setup.yml once;
# safe to re-run (it reuses what already exists).
lane :bootstrap_signing do
  setup_ci
  key = asc_api_key
  sync_signing(api_key: key, bundle_id: ENV.fetch("IOS_BUNDLE_ID"),  match_platform: "ios",  readonly: false)
  sync_signing(api_key: key, bundle_id: ENV.fetch("TVOS_BUNDLE_ID"), match_platform: "tvos", readonly: false)
  UI.success("match signing bootstrapped for iOS + tvOS ✅")
end

platform :ios do
  desc "Build the iPhone/iPad app and upload it to TestFlight"
  lane :beta do
    build_and_upload(
      scheme: "AmeliaPad",
      bundle_id: ENV.fetch("IOS_BUNDLE_ID"),
      destination: "generic/platform=iOS",
      app_platform: "ios",
      match_platform: "ios"
    )
  end
end

platform :tvos do
  desc "Build the Apple TV app and upload it to TestFlight"
  lane :beta do
    build_and_upload(
      scheme: "AmeliaTV",
      bundle_id: ENV.fetch("TVOS_BUNDLE_ID"),
      destination: "generic/platform=tvOS",
      app_platform: "appletvos",
      match_platform: "tvos"
    )
  end
end
